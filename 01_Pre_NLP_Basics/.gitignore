# ===================== 基础忽略（你的原有配置） =====================
# 虚拟环境
nlp.venv/
venv/
.env/
# IDE 配置目录
.idea/
# Python 缓存
__pycache__/
*.py[cod]

# ===================== NLP 项目补充项 =====================
# Python 缓存扩展
*$py.class
.pytest_cache/      # pytest 测试缓存
.coverage           # 测试覆盖率文件
htmlcov/            # 测试覆盖率可视化文件

# Jupyter Notebook 相关（你的项目有 PyTroch_test.ipynb，必加）
.ipynb_checkpoints/ # Notebook 自动保存的检查点文件
*.ipynb.meta        # Notebook 元数据文件

# 数据文件（NLP 项目常包含数据集/日志，体积大且无需上传）
data/               # 数据集文件夹（若有）
datasets/           # 数据集文件夹（若有）
*.csv               # 若有小数据集想保留，可注释此行
*.xlsx
*.jsonl             # NLP 常用的文本行格式
logs/               # 日志文件夹
*.log

# 系统/临时文件
.DS_Store           # Mac 系统隐藏文件
Thumbs.db           # Windows 系统缩略图文件
*.swp               # Vim 编辑器临时文件
*~                  # 临时文件通用后缀

# 模型文件（NLP 模型体积极大，绝对不上传）
*.pth               # PyTorch 模型文件
*.pt                # PyTorch 模型文件
models/             # 模型保存文件夹
checkpoints/        # 训练断点文件夹